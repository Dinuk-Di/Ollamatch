{
  "manifest_version": 3,
  "name": "Ollamatch",
  "version": "1.0.0",
  "description": "AI-powered job matching assistant. Scrape pages, OCR images, score your CV against job descriptions, and generate tailored content — all powered by local Ollama.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.tsx"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* https://*;"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"],
      "use_dynamic_url": true
    }
  ],
  "icons": {
    "16": "src/assets/logo.png",
    "48": "src/assets/logo.png",
    "128": "src/assets/logo.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": "src/assets/logo.png",
    "default_title": "Ollamatch Settings"
  }
}
